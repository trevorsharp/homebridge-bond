{
  "name": "homebridge-bond",
  "version": "3.3.0-beta.3",
  "description": "A homebridge plugin to control your Bond devices over the v2 API.",
  "license": "MIT",
  "main": "dist/index.js",
  "scripts": {
    "lint": "eslint src/**.ts",
    "watch": "npm run build && npm link && nodemon",
    "dev": "tsc --watch & nodemon dist",
    "build": "rimraf ./dist && tsc -p tsconfig-build.json",
    "prepublishOnly": "npm run lint && npm run build",
    "test": "mocha -r ts-node/register tests/**/*.spec.ts",
    "coverage": "nyc -r lcov -e .ts -x \"*.spec.ts\" npm run test"
  },
  "keywords": [
    "homebridge-plugin",
    "bond",
    "bond-home",
    "rf",
    "ir"
  ],
  "repository": {
    "type": "git",
    "url": "git://github.com/aarons22/homebridge-bond.git"
  },
  "bugs": {
    "url": "http://github.com/aarons22/homebridge-bond/issues"
  },
  "engines": {
    "node": "^18.20.4 || ^20.15.1 || ^22 || ^24",
    "homebridge": "^1.6.0 || ^2.0.0-beta.0"
  },
  "devDependencies": {
    "@types/chai": "4.3.11",
    "@types/flake-idgen": "0.1.34",
    "@types/mocha": "10.0.10",
    "@types/node": "20.19.27",
    "@typescript-eslint/eslint-plugin": "4.33.0",
    "@typescript-eslint/parser": "4.33.0",
    "chai": "4.3.10",
    "eslint": "7.32.0",
    "homebridge": "2.0.0-beta.68",
    "mocha": "11.7.5",
    "nodemon": "3.1.7",
    "nyc": "15.1.0",
    "rimraf": "3.0.2",
    "ts-node": "10.9.1",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "axios": "1.16.1",
    "axios-retry": "3.9.1",
    "biguint-format": "1.0.2",
    "flake-idgen": "1.4.0"
  },
  "overrides": {
    "diff": "8.0.4",
    "mocha": {
      "js-yaml": "4.1.1"
    },
    "serialize-javascript": "7.0.5"
  },
  "homepage": "https://github.com/aarons22/homebridge-bond#readme",
  "author": "Aaron Sapp"
}
